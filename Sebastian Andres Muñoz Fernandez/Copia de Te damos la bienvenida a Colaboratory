a', 'N/A')} | Modelos Compatibles: {prod.get('modelos_compatibles', 'N/A')}\")\n","        print(f\"  Garantía (meses): {prod.get('garantia_meses', 'N/A')} | Fecha Registro: {prod.get('fecha_registro', 'N/A')}\")\n","        print(f\"  Peso (kg): {prod.get('peso', 'N/A')} | Material: {prod.get('material', 'N/A')} | Compatibilidad Año: {prod.get('compatibilidad_anio', 'N/A')}\")\n","\n","        print(\"\\n--- Opciones de Modificación ---\")\n","        print(\"1. Agregar/Reducir Stock (Solo Repuestos)\")\n","        print(\"2. Cambiar Precio\")\n","        print(\"3. Cambiar Nombre\")\n","        print(\"4. Cambiar Marca\")\n","        print(\"5. Cambiar Proveedor\")\n","        print(\"6. Cambiar Ubicación\")\n","        print(\"7. Cambiar Stock Mínimo (Solo Repuestos)\")\n","        print(\"8. Cambiar Modelos Compatibles\")\n","        print(\"9. Cambiar Garantía en Meses\")\n","        print(\"10. Cancelar\")\n","        op_mod = input(\"Seleccionar una opción: \")\n","        try:\n","            match op_mod:\n","              case \"1\":\n","                  if prod['tipo'] == \"Repuesto\":\n","                      cantidad_str = input(\"Ingrese la cantidad a agregar o reducir (ej. 5 para agregar, -2 para reducir): \")\n","                      cantidad = int(cantidad_str)\n","\n","                      if (prod['stock'] + cantidad) >= 0:\n","                          prod['stock'] += cantidad\n","                          print(f\"Stock actualizado. Nuevo total: {prod['stock']} unidades.\")\n","                      else:\n","                          print(f\"No se puede reducir el stock a menos de 0. Stock actual: {prod['stock']}\")\n","                  else:\n","                      print(\"Esta opción solo aplica para repuestos, no para servicios.\")\n","\n","              case \"2\":\n","                  nuevo_precio = float(input(\"Ingresa el nuevo precio: \"))\n","                  if nuevo_precio >= 0:\n","                    prod['precio'] = nuevo_precio\n","                    print(f\"Precio actualizado a: ${prod['precio']:.2f}.\")\n","                  else:\n","                    print(\"El precio no puede ser negativo.\")\n","\n","              case \"3\":\n","                  prod['nombre'] = input(\"Ingrese el nuevo nombre: \")\n","                  print(\"Nombre actualizado.\")\n","\n","              case \"4\":\n","                  if prod['tipo'] == \"Repuesto\":\n","                      prod['marca'] = input(\"Ingrese la nueva marca: \")\n","                      print(\"Marca actualizada.\")\n","                  else:\n","                      print(\"Los servicios no tienen marca.\")\n","\n","              case \"5\":\n","                  prod['proveedor'] = input(\"Ingrese el nuevo proveedor: \")\n","                  print(\"Proveedor actualizado.\")\n","\n","              case \"6\":\n","                  prod['ubicacion'] = input(\"Ingrese la nueva ubicación: \")\n","                  print(\"Ubicación actualizada.\")\n","\n","              case \"7\":\n","                  if prod['tipo'] == \"Repuesto\":\n","                      nuevo_min_stock = int(input(\"Ingrese el nuevo stock mínimo: \"))\n","                      if nuevo_min_stock >= 0:\n","                          prod['min_stock'] = nuevo_min_stock\n","                          print(\"Stock mínimo actualizado.\")\n","                      else:\n","                          print(\"El stock mínimo no puede ser negativo.\")\n","                  else:\n","                      print(\"Esta opción solo aplica para repuestos.\")\n","\n","              case \"8\":\n","                  prod['modelos_compatibles'] = input(\"Ingrese los nuevos modelos compatibles (separados por coma): \")\n","                  print(\"Modelos compatibles actualizados.\")\n","\n","              case \"9\":\n","                  nueva_garantia = int(input(\"Ingrese la nueva garantía en meses: \"))\n","                  if nueva_garantia >= 0:\