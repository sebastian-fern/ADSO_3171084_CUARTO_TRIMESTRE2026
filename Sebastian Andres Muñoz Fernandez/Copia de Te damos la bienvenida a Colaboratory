(\"Esta opción solo aplica para repuestos.\")\n","\n","              case \"8\":\n","                  prod['unidad_medida'] = input(\"Ingrese la nueva unidad de medida: \")\n","                  print(\"Unidad de medida actualizada.\")\n","\n","              case \"9\":\n","                  prod['modelos_compatibles'] = input(\"Ingrese los nuevos modelos compatibles (separados por coma): \")\n","                  print(\"Modelos compatibles actualizados.\")\n","\n","              case \"10\":\n","                  nueva_garantia = int(input(\"Ingrese la nueva garantía en meses: \"))\n","                  if nueva_garantia >= 0:\n","                      prod['garantia_meses'] = nueva_garantia\n","                      print(\"Garantía en meses actualizada.\")\n","                  else:\n","                      print(\"La garantía no puede ser negativa.\")\n","\n","              case \"11\":\n","                  if prod['tipo'] == \"Repuesto\":\n","                      nuevo_peso = float(input(\"Ingrese el nuevo peso (en kg): \"))\n","                      if nuevo_peso >= 0:\n","                          prod['peso'] = nuevo_peso\n","                          print(\"Peso actualizado.\")\n","                      else:\n","                          print(\"El peso no puede ser negativo.\")\n","                  else:\n","                      print(\"Esta opción solo aplica para repuestos.\")\n","\n","              case \"12\":\n","                  if prod['tipo'] == \"Repuesto\":\n","                      prod['material'] = input(\"Ingrese el nuevo material: \")\n","                      print(\"Material actualizado.\")\n","                  else:\n","                      print(\"Esta opción solo aplica para repuestos.\")\n","\n","              case \"13\":\n","                  if prod['tipo'] == \"Repuesto\":\n","                      prod['compatibilidad_anio'] = input(\"Ingrese la nueva compatibilidad por año (ej. 2005-2015 o 2010-Actual): \")\n","     